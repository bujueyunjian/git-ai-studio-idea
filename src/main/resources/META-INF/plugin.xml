<idea-plugin>
    <id>com.gitaistudio.idea</id>
    <name>Git AI Studio</name>
    <vendor url="https://github.com/bujueyunjian/git-ai-studio-idea">git-ai-studio</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.vcs</depends>

    <resource-bundle>messages.GitAiStudioBundle</resource-bundle>

    <description><![CDATA[
        Local AI code-authorship insight inside your IDE, on top of the external
        <a href="https://github.com/git-ai-project/git-ai">git-ai</a> CLI.
        Environment diagnostics, git-ai install/upgrade, official hook setup, commit attribution,
        a cross-repo dashboard, per-person breakdown, git-notes attribution log, and in-editor
        line-level AI attribution in the gutter. All parsing happens locally — zero data upload,
        zero telemetry.
    ]]></description>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="com.gitaistudio.idea.service.GitAiSettings"/>
        <projectService serviceImplementation="com.gitaistudio.idea.service.RepoService"/>
        <projectService serviceImplementation="com.gitaistudio.idea.service.StatsCache"/>

        <toolWindow
            id="Git AI Studio"
            anchor="right"
            icon="/icons/toolwindow.svg"
            factoryClass="com.gitaistudio.idea.toolwindow.GitAiToolWindowFactory"/>

        <notificationGroup
            id="Git AI Studio"
            displayType="BALLOON"
            key="notification.group.name"/>

        <statusBarWidgetFactory
            id="GitAiStudio.AiShare"
            implementation="com.gitaistudio.idea.statusbar.AiShareStatusBarWidgetFactory"
            order="last"/>

        <!-- 原生 Git Log「AI 占比」列:提交级归因进 IDE 原生历史界面 -->
        <vcsLogCustomColumn implementation="com.gitaistudio.idea.vcslog.AiShareLogColumn"/>

        <!-- 原生 Annotate(blame)gutter「AI」列:行级归因进 IDE 原生 blame -->
        <vcsAnnotationGutterColumnProvider implementation="com.gitaistudio.idea.annotate.AiAnnotationColumnProvider"/>

        <!-- 启动时检查插件新版本(唯一外网调用,仅版本号) -->
        <postStartupActivity implementation="com.gitaistudio.idea.update.UpdateCheckActivity"/>
    </extensions>

    <actions>
        <!-- 动作只定义一次(无 add-to-group),名字见名知义;由下方「Git AI」子菜单聚合。 -->
        <!-- 命名对齐 git-ai 命令词汇:blame / stats / dashboard -->
        <action id="GitAiStudio.AnnotateAttribution"
                class="com.gitaistudio.idea.editor.AnnotateAttributionAction"
                icon="/icons/toolwindow.svg"
                text="Blame"
                description="Toggle per-line AI (purple) vs. human (blue) authorship in the gutter, via git-ai blame-analysis">
            <add-to-group group-id="EditorGutterPopupMenu" anchor="last"/>
        </action>
        <action id="GitAiStudio.FileAiSummary"
                class="com.gitaistudio.idea.editor.FileAiSummaryAction"
                icon="/icons/toolwindow.svg"
                text="Stats"
                description="Show this file's AI share inline (committed + working tree), via git-ai stats/blame-analysis"/>
        <action id="GitAiStudio.ViewFileAttribution"
                class="com.gitaistudio.idea.editor.ViewFileAttributionAction"
                icon="/icons/toolwindow.svg"
                text="Blame in Panel"
                description="Open this file's line-level blame drill-down in the Git AI Studio tool window"/>
        <action id="GitAiStudio.ViewProjectMetrics"
                class="com.gitaistudio.idea.editor.ViewProjectMetricsAction"
                icon="/icons/toolwindow.svg"
                text="Dashboard"
                description="Open the project's attribution dashboard in the Git AI Studio tool window"/>

        <!-- 编辑器右键:「Git AI」子菜单 -->
        <group id="GitAiStudio.EditorMenu" text="Git AI" popup="true" icon="/icons/toolwindow.svg">
            <reference ref="GitAiStudio.AnnotateAttribution"/>
            <reference ref="GitAiStudio.FileAiSummary"/>
            <separator/>
            <reference ref="GitAiStudio.ViewFileAttribution"/>
            <reference ref="GitAiStudio.ViewProjectMetrics"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </group>

        <!-- 项目树右键:「Git AI」子菜单(无编辑器,只放面板类) -->
        <group id="GitAiStudio.ProjectViewMenu" text="Git AI" popup="true" icon="/icons/toolwindow.svg">
            <reference ref="GitAiStudio.ViewFileAttribution"/>
            <reference ref="GitAiStudio.ViewProjectMetrics"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </group>
    </actions>
</idea-plugin>
